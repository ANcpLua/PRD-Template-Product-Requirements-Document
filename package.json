{
  "name": "prd-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Interactive Product Requirements Document template — a clean, accessible single-page reader deployed to GitHub Pages.",
  "homepage": "https://ancplua.github.io/PRD-Template-Product-Requirements-Document/",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,css,md,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,css,md,html}\"",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.0.16"
  }
}
